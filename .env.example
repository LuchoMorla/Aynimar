# ─────────────────────────────────────────────────────────────────────────────
# AYNIMAR BACKEND — Railway Environment Variables
# Copy this file to .env for local development.
# All secrets must be set in Railway → Variables before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=aynimar
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ── Server ────────────────────────────────────────────────────────────────────
PORT=6969
JWT_SECRET=your_jwt_secret_here
TEMPORALY_JWT_SECRET=your_temp_jwt_secret_here
API_KEY=your_api_key_here

# ── CORS / URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL=https://www.aynimar.com
FRONTEND_DASHBOARD_URL=https://circular-merchant.aynimar.com

# ─────────────────────────────────────────────────────────────────────────────
# AUTOPISTA LOGÍSTICA — Dropi + Cloudflare Worker
# These are the ONLY Dropi-related vars. WooCommerce consumer keys
# belong in the businesses table (set via Dashboard → Business → Settings),
# NOT here.
# ─────────────────────────────────────────────────────────────────────────────

# Cloudflare Worker (Woomirror) — bypasses Dropi WAF from Railway datacenter
DROPI_WORKER_URL=https://your-worker.workers.dev
DROPI_WORKER_KEY=your_cloudflare_worker_secret_key

# Dropi account credentials — used by dropiAuthService to auto-refresh JWT
DROPI_EMAIL=your_dropi_email@example.com
DROPI_PASSWORD=your_dropi_password

# Dropi order/fulfillment API Bearer JWT (api.dropi.co)
# Previously stored as WOO_CONSUMER_SECRET — renamed for clarity.
# Fallback to WOO_CONSUMER_SECRET is kept in code during migration.
DROPI_ORDER_TOKEN=your_dropi_order_bearer_token

# Optional: pre-load a Dropi session token to skip initial login
# DROPI_SESSION_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: TOTP secret if Dropi requires 2FA
# DROPI_2FA_SECRET=JBSWY3DPEHPK3PXP

# Optional: override Dropi catalog base URL (default: https://api.dropi.ec)
# DROPI_API_URL=https://api.dropi.ec

# ─────────────────────────────────────────────────────────────────────────────
# WooCommerce Mirror (Dropi → Aynimar catalog sync)
# Dropi calls /wp-json/wc/v3/* using Basic Auth with per-business credentials.
# These credentials are stored in the `businesses` table, NOT as env vars.
# To configure: Dashboard → Business → Settings → enter Key + Secret.
# The values Dropi gives you (FRONT_WOO_CONSUMER_KEY / FRONT_WOO_CONSUMER_SECRET)
# go into that settings form, not into Railway.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email (NodeMailer / Resend) ───────────────────────────────────────────────
GPASS=your_gmail_app_password
SMAIL=sender@yourdomain.com
RMAIL=receiver@yourdomain.com
RESEND_API_KEY=re_your_resend_api_key

# ── pgAdmin (local dev only) ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@mail.com
PGADMIN_DEFAULT_PASSWORD=root
