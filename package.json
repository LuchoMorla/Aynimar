{
  "name": "aynimar",
  "version": "1.0.0",
  "description": "circular economy and recycling application",
  "main": "index.js",
  "scripts": {
    "test": "node scripts/smoke-test.js",
    "smoke-test": "node scripts/smoke-test.js",
    "health-check": "node scripts/health-check.js",
    "post-deploy": "node scripts/post-deploy.js",
    "install-hooks": "sh scripts/install-hooks.sh",
    "dev": "nodemon index.js",
    "prestart": "./node_modules/.bin/sequelize db:migrate || echo '[prestart] Migration warning — DB may be unavailable; server starting anyway'",
    "start": "node index.js",
    "lint": "eslint",
    "idocker": "docker-compose --env-file .env up -d aynapi-postgres pgadmin",
    "migrations:generate": "sequelize-cli migration:generate --name",
    "migrations:run": "sequelize-cli db:migrate",
    "migrations:revert": "sequelize-cli db:migrate:undo",
    "migrations:delete": "sequelize-cli db:migrate:undo:all"
  },
  "keywords": [],
  "author": "Luis Morla",
  "license": "CC-BY-4.0",
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^2.4.1"
  },
  "dependencies": {
    "@hapi/boom": "^9.1.4",
    "@sentry/node": "^10.62.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^16.0.1",
    "express": "^4.22.2",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.5.2",
    "faker": "^5.5.3",
    "joi": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "resend": "^6.16.0",
    "semver": "^7.6.2",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
